    "description": "schema:description",
    "url": "schema:url",
    "Organization": "schema:Organization",
    "SoftwareApplication": "schema:SoftwareApplication",
    "WebAPI": "schema:WebAPI",

    "Trace": "langwatch:Trace",
    "Span": "langwatch:Span",
    "Evaluator": "langwatch:Evaluator",
    "Evaluation": "langwatch:Evaluation",
    "Monitor": "langwatch:Monitor",
    "Dataset": "langwatch:Dataset",
    "DatasetRecord": "langwatch:DatasetRecord",
    "Prompt": "langwatch:Prompt",
    "PromptVersion": "langwatch:PromptVersion",
    "Scenario": "langwatch:Scenario",
    "SimulationRun": "langwatch:SimulationRun",
    "Suite": "langwatch:Suite",
    "Experiment": "langwatch:Experiment",
    "ExperimentRun": "langwatch:ExperimentRun",
    "Annotation": "langwatch:Annotation",
    "Dashboard": "langwatch:Dashboard",
    "Graph": "langwatch:Graph",
    "Project": "langwatch:Project",
    "ApiKey": "langwatch:ApiKey",
    "Secret": "langwatch:Secret",
    "ModelProvider": "langwatch:ModelProvider",
    "VirtualKey": "langwatch:VirtualKey",
    "Budget": "langwatch:Budget",
    "CacheRule": "langwatch:CacheRule",
    "Workflow": "langwatch:Workflow",
    "Agent": "langwatch:Agent",
    "Trigger": "langwatch:Trigger",

    "traceId": "langwatch:traceId",
    "spanId": "langwatch:spanId",
    "parentSpanId": "langwatch:parentSpanId",
    "model": "langwatch:model",
    "modelProvider": "langwatch:modelProvider",
    "promptTokens": "langwatch:promptTokens",
    "completionTokens": "langwatch:completionTokens",
    "totalTokens": "langwatch:totalTokens",
    "cost": "langwatch:cost",
    "score": "langwatch:score",
    "passed": "langwatch:passed",
    "judgeVerdict": "langwatch:judgeVerdict",
    "scenarioId": "langwatch:scenarioId",
    "datasetId": "langwatch:datasetId",
    "promptId": "langwatch:promptId",
    "evaluatorId": "langwatch:evaluatorId",
    "monitorId": "langwatch:monitorId",
    "projectId": "langwatch:projectId",
    "createdAt": "schema:dateCreated",
    "updatedAt": "schema:dateModified",

    "instrumentedBy": "otel:instrumentationScope",
